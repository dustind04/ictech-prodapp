# Copy to .env next to docker-compose.prod.yaml. Never commit .env.

# Cloudflare tunnel token — created in the Zero Trust dashboard
# (Networks -> Tunnels -> Create a tunnel -> Cloudflared). The tunnel's
# Public Hostname should point at  http://ictech:8058
TUNNEL_TOKEN=

# Flask session secret. Generate one:  python3 -c "import secrets; print(secrets.token_hex(32))"
ICTECH_SECRET=

# HTTP Basic Auth for /admin. REQUIRED for an internet-facing deployment —
# with these unset the admin CRUD is wide open. The wall display itself
# stays public by design.
ICTECH_ADMIN_USER=
ICTECH_ADMIN_PASSWORD=
